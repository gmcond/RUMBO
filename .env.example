# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# SOLO servidor (scripts y route handlers). Jamás exponer en cliente (CLAUDE.md regla 5).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Ref del proyecto para la CLI (npm run db:migrate / db:types)
SUPABASE_PROJECT_REF=<project-ref>

# ── App ──────────────────────────────────────────────────────────────────────
# URL pública del sitio (callbacks de auth). En Vercel: https://<dominio>
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Anthropic (pipeline de contenido, Fase 3) ────────────────────────────────
ANTHROPIC_API_KEY=<anthropic-api-key>
